# Ghostty config — translated from Alacritty
# https://ghostty.org/docs/config/reference

# Window
window-decoration = none
maximize = true

# Font
font-family = IosevkaTerm Nerd Font
term = xterm-ghostty
font-family = Maple Mono NF
font-size = 12

# Theme — Kanagawa Dragon (built-in)
theme = Kanagawa Dragon

# Cursor
cursor-style = block

# Mouse
mouse-hide-while-typing = true
mouse-scroll-multiplier = 3

# Scrollback
scrollback-limit = 1000000

# Clipboard
clipboard-read = ask
clipboard-write = allow

# Key bindings
keybind = super+v=paste_from_clipboard
keybind = super+c=copy_to_clipboard
# Karabiner remaps cmd+v→opt+v and cmd+c→opt+c, so bind opt versions too
keybind = alt+v=paste_from_clipboard
keybind = ctrl+slash=text:\x1f
keybind = ctrl+q=esc:\x11
keybind = alt+delete=reset_font_size
keybind = alt+equal=increase_font_size:1
keybind = alt+minus=decrease_font_size:1

bell-features = no-attention
fullscreen = false
confirm-close-surface = false
